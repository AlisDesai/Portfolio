# Public site URL, used for metadata, sitemap, and canonical links.
NEXT_PUBLIC_SITE_URL=http://localhost:3008

# --- Contact form (app/api/contact) ---------------------------------------

# Resend (https://resend.com) API key used to send contact-form inquiry
# emails. Required for the contact form to actually send mail; without it,
# submissions fail with a clear "email delivery not configured" error.
RESEND_API_KEY=

# Inbox that receives contact-form inquiries. Falls back to the address in
# components/features/contact/contact-data.ts (COMPANY_CONTACT.email) if left empty.
CONTACT_TO_EMAIL=

# "From" address for outgoing inquiry emails. Must be on a domain verified
# with Resend before going live -- the default (onboarding@resend.dev) only
# works for local/dev testing.
CONTACT_FROM_EMAIL=

# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# keys for bot protection on the contact form. Leave both empty to disable
# Turnstile locally (the form still works, just without this layer); both
# should be set in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: bind a KV namespace named CONTACT_RATE_LIMIT_KV in your
# Cloudflare Pages/Workers config to enable IP-based rate limiting on the
# contact endpoint (see lib/services/rate-limit.service.ts). This isn't a
# regular env var -- it's configured as a KV binding in your Cloudflare
# deployment settings, not here. Without it, rate limiting is skipped.
